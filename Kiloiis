local BLACKLISTED_TAGS = {
    "sc",
}

local function hasBlacklistedInitials(username)
    local lower = username:lower()
    for _, tag in ipairs(BLACKLISTED_TAGS) do
        local t = tag:lower()
        if lower == t then return true end
        if lower:match("^" .. t .. "[_%-]") then return true end
        if lower:match("[_%-]" .. t .. "$") then return true end
        if lower:match("[_%-]" .. t .. "[_%-]") then return true end
        if lower:match("^" .. t .. "%a") then return true end
        if lower:match("%a" .. t .. "$") then return true end
        if lower:match("^" .. t .. "%d") then return true end
        if lower:match(t .. "user") then return true end
        if lower:match("user" .. t) then return true end
    end
    return false
end

local function kickBlacklistedPlayer(targetPlayer)
    pcall(function() targetPlayer:Kick("[Mystery Hub] Not authorized") end)
end

local function checkAndKickBlacklisted(targetPlayer)
    if targetPlayer == Player then return end
    if hasBlacklistedInitials(targetPlayer.Name) then
        kickBlacklistedPlayer(targetPlayer)
    end
end

for _, p in ipairs(Players:GetPlayers()) do
    checkAndKickBlacklisted(p)
end

Players.PlayerAdded:Connect(function(p)
    task.wait(0.5)
