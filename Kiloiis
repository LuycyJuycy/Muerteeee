        local egg = LocalPlayer.Backpack:FindFirstChild("Protein Egg")
        if egg then egg.Parent = char end
    end

    local punch = char:FindFirstChild("Punch")
    if not punch then
        local bp = LocalPlayer.Backpack:FindFirstChild("Punch")
        if bp then
            bp.Parent = char
            punch = bp
        end
    end

    if punch then
        if punch:FindFirstChild("attackTime") then
            punch.attackTime.Value = 0
        end
        pcall(function() punch:Activate() end)
    end

    if myRoot and rightHand and leftHand then
        for _, target in ipairs(Players:GetPlayers()) do
            if target ~= LocalPlayer and not playerWhitelist[target.Name] then
                local targetChar = target.Character
                local targetRoot = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
                local targetHum = targetChar and targetChar:FindFirstChildOfClass("Humanoid")
                if targetRoot and targetHum and targetHum.Health > 0 then
                    local savedCFrame = targetRoot.CFrame
                    pcall(function()
                        targetRoot.CFrame = myRoot.CFrame * CFrame.new(0, 0, -2)
                    end)
                    pcall(function()
                        firetouchinterest(rightHand, targetRoot, 1)
                        firetouchinterest(leftHand, targetRoot, 1)
                        firetouchinterest(rightHand, targetRoot, 0)
                        firetouchinterest(leftHand, targetRoot, 0)
                    end)
                    pcall(function()
                        targetRoot.CFrame = savedCFrame
                    end)
                end
            end
        end
    end
end)

local AUTO_HOP_INTERVAL = 65
local MIN_PLAYERS = 15
local autoHopEnabled = true

local function getBestServer()
    local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
    local success, serverData = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url, true))
    end)
    if success and serverData and serverData.data then
        local validServers = {}
        for _, server in ipairs(serverData.data) do
            if server.playing and server.playing >= MIN_PLAYERS then
                table.insert(validServers, server)
            end
        end
        if #validServers > 0 then
            return validServers[math.random(1, #validServers)].id
        end
    end
    return nil
end

local function hopToFullServer()
    local bestServerId = getBestServer()
    if bestServerId then
        TeleportService:TeleportToPlaceInstance(game.PlaceId, bestServerId, Player)
    else
        TeleportService:Teleport(game.PlaceId, Player)
    end
end

task.spawn(function()
    while autoHopEnabled do
        task.wait(AUTO_HOP_INTERVAL)
        if autoHopEnabled then hopToFullServer() end
    end
end)

local autoEatBoostsEnabled = true
local boostsList = {"ULTRA Shake", "TOUGH Bar", "Protein Shake", "Energy Shake", "Protein Bar", "Energy Bar", "Tropical Shake"}

local function eatAllBoosts()
    local backpack = Player:WaitForChild("Backpack")
    local character = Player.Character or Player.CharacterAdded:Wait()
    for _, boostName in ipairs(boostsList) do
        local boost = backpack:FindFirstChild(boostName)
        while boost do
            boost.Parent = character
            pcall(function() boost:Activate() end)
            task.wait(0)
            boost = backpack:FindFirstChild(boostName)
        end
    end
end

task.spawn(function()
    while true do
        if autoEatBoostsEnabled then
            eatAllBoosts()
            task.wait(2)
        else
            task.wait(1)
        end
    end
end)

getgenv().posLock = nil
local posLockEnabled = true
local posLockConn = nil

local function startPosLock()
    if posLockConn then posLockConn:Disconnect() end
    local char = Player.Character or Player.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")
    local lockedCFrame = root.CFrame
    posLockConn = game:GetService("RunService").Heartbeat:Connect(function()
        if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
            Player.Character.HumanoidRootPart.CFrame = lockedCFrame
        end
    end)
    getgenv().posLock = posLockConn
end

if posLockEnabled then
    startPosLock()
end

Player.CharacterAdded:Connect(function()
    if posLockEnabled then
        task.wait(0.5)
        startPosLock()
    end
end)

