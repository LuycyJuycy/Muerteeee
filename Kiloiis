        pcall(function()
            if p:IsFriendsWith(Player.UserId) then
                local already = false
                for _, name in ipairs(_G.whitelistedPlayers) do
                    if name:lower() == p.Name:lower() then already = true; break end
                end
                if not already then
                    table.insert(_G.whitelistedPlayers, p.Name)
                    playerWhitelist[p.Name] = true
                end
            end
        end)
    end
end)

